<!DOCTYPE html>
<html lang="<%= lang %>">

<head>
  <%
    const metaTitle = typeof seo !== 'undefined' && seo.title ? seo.title : `${title} - ${t.site.name}`;
    const metaDescription = typeof seo !== 'undefined' && seo.description
      ? seo.description
      : (t.site && t.site.description ? t.site.description : `${t.site.name} English Center`);
    const metaKeywords = typeof seo !== 'undefined' && seo.keywords
      ? seo.keywords
      : (t.site && t.site.keywords ? t.site.keywords : '');
    const canonicalUrl = typeof seo !== 'undefined' && seo.canonical ? seo.canonical : '';
    const ogImage = typeof seo !== 'undefined' && seo.image ? seo.image : '/images/logo.png';
    const ogImageAlt = typeof seo !== 'undefined' && seo.imageAlt ? seo.imageAlt : t.site.name;
    const ogType = typeof seo !== 'undefined' && seo.type ? seo.type : 'website';
    const ogLocale = typeof seo !== 'undefined' && seo.locale ? seo.locale : (lang === 'en' ? 'en_US' : 'vi_VN');
    const robots = typeof seo !== 'undefined' && seo.robots ? seo.robots : 'index, follow';
    const nonceAttribute = typeof cspNonce !== 'undefined' && cspNonce ? ` nonce="${cspNonce}"` : '';
  %>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= metaTitle %></title>
  <meta name="description" content="<%= metaDescription %>">
  <% if (metaKeywords) { %>
    <meta name="keywords" content="<%= metaKeywords %>">
    <% } %>
      <meta name="robots" content="<%= robots %>">
      <meta name="author" content="<%= t.site.name %>">
      <% if (canonicalUrl) { %>
        <link rel="canonical" href="<%= canonicalUrl %>">
        <% } %>
          <meta property="og:site_name" content="<%= t.site.name %>">
          <meta property="og:type" content="<%= ogType %>">
          <meta property="og:locale" content="<%= ogLocale %>">
          <meta property="og:title" content="<%= metaTitle %>">
          <meta property="og:description" content="<%= metaDescription %>">
          <% if (canonicalUrl) { %>
            <meta property="og:url" content="<%= canonicalUrl %>">
            <% } %>
              <meta property="og:image" content="<%= ogImage %>">
              <meta property="og:image:alt" content="<%= ogImageAlt %>">
              <meta name="twitter:card" content="summary_large_image">
              <meta name="twitter:title" content="<%= metaTitle %>">
              <meta name="twitter:description" content="<%= metaDescription %>">
              <meta name="twitter:image" content="<%= ogImage %>">
  <link rel="icon" type="image/png" href="/images/logo.png">
  <link rel="shortcut icon" type="image/png" href="/images/logo.png">
  <link rel="apple-touch-icon" href="/images/logo.png">
  <link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
  <link rel="stylesheet" href="/vendor/font-awesome/css/all.min.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <% if (typeof pageCss !=='undefined' && pageCss) { %>
    <link rel="stylesheet" href="/css/pages/<%= pageCss %>.css">
    <% } %>
      <% if (typeof structuredData !== 'undefined' && structuredData) { %>
        <% const structuredDataItems = Array.isArray(structuredData) ? structuredData : [structuredData]; %>
          <% structuredDataItems.forEach((item)=> { %>
            <script type="application/ld+json"<%- nonceAttribute %>><%- JSON.stringify(item) %></script>
            <% }) %>
              <% } %>
</head>

<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">
        <img src="/images/logo.png" alt="<%= t.site.name %>" onerror="this.style.display='none'">
        <span class="site-logo-text">
          <%= t.site.name %>
        </span>
      </a>
      <button class="mobile-toggle" id="mobileToggle" aria-label="Menu">
        <i class="bi bi-list"></i>
      </button>
      <ul class="nav-menu" id="navMenu">
        <% visibleMenus.forEach(menu=> { %>
          <% const menuName=lang==='en' && menu.name_en ? menu.name_en : menu.name_vi; %>
            <% if (menu.type==='post_list' ) { %>
              <li>
                <a href="#">
                  <%= menuName %> <i class="bi bi-chevron-down" style="font-size:0.7rem;"></i>
                </a>
                <ul class="nav-dropdown">
                  <% (menu.children || []).forEach(post=> { %>
                    <li><a href="/posts/<%= post.slug %>">
                        <%= lang==='en' && post.title_en ? post.title_en : post.title %>
                      </a></li>
                    <% }) %>
                </ul>
              </li>
              <% } else { %>
                <li><a href="<%= menu.url || '/menu/' + menu.slug %>">
                    <%= menuName %>
                  </a></li>
                <% } %>
                  <% }) %>
      </ul>
      <div class="header-right">
        <!-- <div class="header-language" id="langToggle">
          <span>
            <%= lang==='en' ? 'EN' : 'VI' %> <i class="bi bi-chevron-down dropdown-icon" style="font-size:0.7rem;"></i>
          </span>
          <div class="header-language-menu">
            <a href="/lang/vi">Tiếng Việt</a>
            <a href="/lang/en">English</a>
          </div>
        </div> -->
        <div class="header-cta">
          <a href="/lich-khai-giang" class="btn-gold btn btn-sm">
            <%= t.header.cta %>
          </a>
        </div>
      </div>
    </div>
  </header>
  <main>
    <% if (success) { %>
      <div class="flash-container">
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      </div>
      <% } %>
        <% if (error) { %>
          <div class="flash-container">
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          </div>
          <% } %>
