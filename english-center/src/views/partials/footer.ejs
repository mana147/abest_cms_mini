  </main>
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-col">
        <div class="footer-logo">
          <img src="/images/logo02.png" alt="<%= t.site.name %>" onerror="this.style.display='none'">
          <span><%= t.site.name %></span>
        </div>
        <p><%= t.footer.about_text %></p>
      </div>
      <div class="footer-col">
        <h5><%= t.footer.contact_info %></h5>
        <ul class="footer-contact">
          <li><i class="bi bi-geo-alt-fill"></i><span><%= t.footer.address %></span></li>
          <li><i class="bi bi-telephone-fill"></i><span><%= t.footer.phone %></span></li>
          <li><i class="bi bi-envelope-fill"></i><span><%= t.footer.email %></span></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5><%= t.footer.quick_links %></h5>
        <ul class="footer-links">
          <% visibleMenus.slice(0, 6).forEach(menu => { %>
            <li><a href="<%= menu.type === 'post_list' ? '#' : (menu.url || '/menu/' + menu.slug) %>"><%= lang === 'en' && menu.name_en ? menu.name_en : menu.name_vi %></a></li>
          <% }) %>
        </ul>
      </div>
      <div class="footer-col">
        <h5><%= t.footer.follow_us %></h5>
        <div class="footer-socials">
          <a href="#"><i class="bi bi-facebook"></i></a>
          <a href="#"><i class="bi bi-instagram"></i></a>
          <a href="#"><i class="bi bi-youtube"></i></a>
        </div>
        <div class="cookie-box" id="cookieConsent">
          <p><%= t.footer.cookie_text %></p>
          <button type="button" class="btn-navy btn btn-sm w-100" id="cookieAccept"><%= t.footer.cookie_accept %></button>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div><%= t.footer.legal_info %></div>
      &copy; <%= new Date().getFullYear() %> <%= t.footer.copyright %>
    </div>
  </footer>
  <div class="zalo-widget">
    <a href="https://zalo.me/0969760322" target="_blank" rel="noreferrer noopener">
      <img src="/images/icons/zalo-icon.png" alt="Zalo">
      <span>Chat</span>
    </a>
  </div>

  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/js/landing.js"></script>
</body>
</html>
