<%- include('../partials/header', { pageCss: 'courses' }) %>

<div class="page-banner">
  <div class="container">
    <h1><%= t.courses.title %></h1>
  </div>
</div>

<section class="section">
  <div class="container">
    <% if (courses.length === 0) { %>
      <div class="empty-state"><i class="bi bi-journal-x"></i><%= t.courses.empty %></div>
    <% } else { %>
      <div class="row g-4">
        <% courses.forEach(course => { %>
          <div class="col-md-4">
            <div class="card-custom">
              <div class="course-card-thumb">
                <% if (course.thumbnail) { %>
                  <img src="<%= course.thumbnail %>" alt="<%= course.title %>" style="width:100%;aspect-ratio:4/3;object-fit:cover;">
                <% } else { %>
                  <div class="placeholder-img"><i class="bi bi-journal-bookmark"></i></div>
                <% } %>
                <% if (course.level) { %><span class="badge-gold course-card-level"><%= course.level %></span><% } %>
              </div>
              <div class="card-body">
                <h5><%= lang === 'en' && course.title_en ? course.title_en : course.title %></h5>
                <p class="text-muted small"><%= lang === 'en' && course.description_en ? course.description_en : course.description %></p>
                <div class="course-meta">
                  <% if (course.duration) { %><span><i class="bi bi-clock"></i><%= course.duration %></span><% } %>
                  <% if (course.schedule) { %><span><i class="bi bi-calendar3"></i><%= course.schedule %></span><% } %>
                </div>
                <% if (course.fee) { %><div class="course-fee"><%= course.fee %></div><% } %>
                <a href="/khoa-hoc/<%= course.slug %>" class="btn-outline-navy btn btn-sm mt-2"><%= t.courses.detail %></a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
