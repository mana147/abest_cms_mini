<%- include('../partials/header') %>

<div class="page-banner">
  <div class="container">
    <h1><%= t.posts.title %></h1>
  </div>
</div>

<section class="section">
  <div class="container">
    <% if (posts.length === 0) { %>
      <div class="empty-state"><i class="bi bi-newspaper"></i><%= t.posts.empty %></div>
    <% } else { %>
      <div class="row g-4">
        <% posts.forEach(post => { %>
          <div class="col-md-4">
            <div class="card-custom">
              <% if (post.thumbnail) { %>
                <img src="<%= post.thumbnail %>" alt="<%= post.title %>" style="width:100%;aspect-ratio:16/10;object-fit:cover;">
              <% } else { %>
                <div class="placeholder-img" style="aspect-ratio:16/10;"><i class="bi bi-newspaper"></i></div>
              <% } %>
              <div class="card-body">
                <h5><%= lang === 'en' && post.title_en ? post.title_en : post.title %></h5>
                <p class="text-muted small"><%= lang === 'en' && post.excerpt_en ? post.excerpt_en : post.excerpt %></p>
                <a href="/posts/<%= post.slug %>" class="btn-outline-navy btn btn-sm"><%= t.posts.read_more %></a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
