<%- include('../partials/header', { pageCss: 'contact' }) %>

<div class="page-banner">
  <div class="container">
    <h1><%= t.contact.title %></h1>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="row g-4">
      <div class="col-lg-5">
        <div class="contact-info-card">
          <i class="bi bi-geo-alt-fill"></i>
          <div><%= t.footer.address %></div>
        </div>
        <div class="contact-info-card">
          <i class="bi bi-telephone-fill"></i>
          <div><%= t.footer.phone %></div>
        </div>
        <div class="contact-info-card">
          <i class="bi bi-envelope-fill"></i>
          <div><%= t.footer.email %></div>
        </div>
      </div>
      <div class="col-lg-7">
        <div class="contact-form">
          <form action="/contact" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="mb-3">
              <label class="form-label"><%= t.schedule.full_name %> *</label>
              <input type="text" name="full_name" class="form-control" required>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label"><%= t.schedule.email %></label>
                <input type="email" name="email" class="form-control">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label"><%= t.schedule.phone %></label>
                <input type="text" name="phone" class="form-control">
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label"><%= t.contact.subject %></label>
              <input type="text" name="subject" class="form-control">
            </div>
            <div class="mb-3">
              <label class="form-label"><%= t.schedule.message %> *</label>
              <textarea name="message" class="form-control" rows="4" required></textarea>
            </div>
            <button type="submit" class="btn-gold btn"><%= t.contact.submit %></button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section-map">
  <div class="container">
    <div class="section-heading mb-4">
      <h2><%= t.contact.map_title %></h2>
    </div>
    <div class="map-wrapper">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d232.7854368157017!2d105.80571867897937!3d21.009987670562236!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ac9f8bb31cb1%3A0x466acd682f9eaaf7!2zMTY4IFAuIEhvw6BuZyBOZ8OibiwgWcOqbiBIw7JhLCBIw6AgTuG7mWksIFZp4buHdCBOYW0!5e0!3m2!1svi!2s!4v1782116474318!5m2!1svi!2s"
        style="border:0;"
        allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
