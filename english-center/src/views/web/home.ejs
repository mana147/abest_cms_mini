<section class="section method-section" id="roadmap">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <h2 class="method-title"><%= t.home.method_title %></h2>
        <p class="text-muted fs-5"><%= t.home.method_text %></p>
        <a href="/khoa-hoc" class="btn-pink btn d-inline-flex align-items-center gap-2"><%= t.home.method_cta %> <i class="bi bi-arrow-right"></i></a>
      </div>
      <div class="col-lg-6">
        <img src="/images/homepage-method.png" alt="<%= t.home.method_title %>" class="method-image">
      </div>
    </div>
  </div>
</section>


<section class="section bg-alt">
  <div class="container">
    <h2 class="section-title"><%= t.home.courses_title %></h2>
    <p class="section-subtitle"><%= t.home.courses_subtitle %></p>
    <% if (courses.length === 0) { %>
      <div class="empty-state"><i class="bi bi-journal-x"></i><%= t.courses.empty %></div>
    <% } else { %>
      <div class="courses-scroll">
        <% courses.forEach(course => { %>
          <div class="snap-card">
            <div class="card-custom h-100">
              <div class="course-card-thumb">
                <% if (course.thumbnail) { %>
                  <img src="<%= course.thumbnail %>" alt="<%= course.title %>" style="width:100%;height:220px;object-fit:cover;">
                <% } else { %>
                  <div class="placeholder-img" style="aspect-ratio:auto;height:220px;"><i class="bi bi-journal-bookmark"></i></div>
                <% } %>
                <% if (course.level) { %><span class="badge-gold course-card-level"><%= course.level %></span><% } %>
              </div>
              <div class="card-body">
                <h5><%= lang === 'en' && course.title_en ? course.title_en : course.title %></h5>
                <ul class="course-meta-list">
                  <% if (course.duration) { %><li><i class="bi bi-clock"></i> <%= course.duration %></li><% } %>
                  <% if (course.fee) { %><li><i class="bi bi-tag"></i> <%= course.fee %></li><% } %>
                </ul>
                <a href="/khoa-hoc/<%= course.slug %>" class="btn-navy btn btn-sm w-100"><%= t.courses.detail %></a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
    <div class="text-center mt-4"><a href="/khoa-hoc" class="btn-outline-navy btn"><%= t.home.courses_view_all %></a></div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="section-title"><%= t.home.teachers_title %></h2>
    <p class="section-subtitle"><%= t.home.teachers_subtitle %></p>
    <% if (teachers.length === 0) { %>
      <div class="empty-state"><i class="bi bi-person-x"></i><%= t.teachers.empty %></div>
    <% } else { %>
      <div class="row g-4">
        <% teachers.forEach(teacher => { %>
          <div class="col-md-6 col-lg-3">
            <div class="instructor-card">
              <div class="instructor-photo">
                <% if (teacher.photo) { %>
                  <img src="<%= teacher.photo %>" alt="<%= teacher.name %>">
                <% } else { %>
                  <div class="placeholder-img placeholder-round"><i class="bi bi-person"></i></div>
                <% } %>
              </div>
              <div class="instructor-body">
                <h5><%= teacher.name %></h5>
                <p class="instructor-role"><%= lang === 'en' && teacher.qualification_en ? teacher.qualification_en : teacher.qualification %></p>
                <% const bio = lang === 'en' && teacher.bio_en ? teacher.bio_en : teacher.bio; %>
                <% if (bio) { %><p class="instructor-bio"><%= bio.length > 90 ? bio.slice(0, 90) + '…' : bio %></p><% } %>
                <a href="/lich-khai-giang" class="btn-pink btn btn-sm w-100"><%= t.home.hero_cta %></a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
    <div class="text-center mt-4"><a href="/giao-vien" class="btn-navy btn"><%= t.home.teachers_view_all %></a></div>
  </div>
</section>

<section class="section"  style="background-image:url('/images/abest_bg_2.png');" >
  <div class="container">
    <h2 class="section-title"><%= t.home.products_title %></h2>
    <p class="section-subtitle"><%= t.home.products_subtitle %></p>
    <div class="row g-4">
      <div class="col-md-6 col-lg-4">
        <div class="student-product-card">
          <div class="product-icon"><i class="bi bi-mic-fill"></i></div>
          <span class="badge-pink"><%= lang === 'en' ? 'Speaking' : 'Speaking' %></span>
          <h5><%= lang === 'en' ? 'Speaking Advanced Document Set' : 'Bộ Tài Liệu Speaking Advanced' %></h5>
          <p class="product-student"><%= lang === 'en' ? 'Hoang Minh Anh – Band 8.0' : 'Hoàng Minh Anh - Band 8.0' %></p>
          <p class="text-muted small"><%= lang === 'en' ? 'A collection of Speaking part 1, 2, 3 topics with transcripts and detailed analysis for band 7.5+.' : 'Tuyển tập các chủ đề Speaking part 1, 2, 3 với transcript và phân tích chi tiết dành cho band 7.5+.' %></p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="student-product-card">
          <div class="product-icon"><i class="bi bi-pencil-fill"></i></div>
          <span class="badge-pink">Writing</span>
          <h5><%= lang === 'en' ? 'Writing Task 1 & 2 Collection' : 'Writing Task 1 & 2 Collection' %></h5>
          <p class="product-student"><%= lang === 'en' ? 'Nguyen Thao – Band 7.5' : 'Nguyễn Thảo - Band 7.5' %></p>
          <p class="text-muted small"><%= lang === 'en' ? 'A collection of essays, letters and diagrams scored 8.5/9.0 with detailed teacher feedback.' : 'Bộ sưu tập các bài essays, letters, diagrams được chấm 8.5/9.0 với nhận xét chi tiết từ giáo viên.' %></p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="student-product-card">
          <div class="product-icon"><i class="bi bi-volume-up-fill"></i></div>
          <span class="badge-pink">Listening</span>
          <h5><%= lang === 'en' ? 'IELTS Listening Podcast' : 'Podcast Luyện Nghe IELTS' %></h5>
          <p class="product-student"><%= lang === 'en' ? 'Le Quang Hai – Band 8.5' : 'Lê Quang Hải - Band 8.5' %></p>
          <p class="text-muted small"><%= lang === 'en' ? 'A 50-episode podcast series with different accents and varied topics for realistic exam practice.' : 'Series podcast 50 tập với các accent khác nhau, chủ đề đa dạng phù hợp luyện thi thực tế.' %></p>
        </div>
      </div>
    </div>
    <div class="text-center mt-4"><a href="/posts" class="btn-outline-navy btn"><%= t.home.products_cta %></a></div>
  </div>
</section>

<% if (testimonials.length > 0) { %>
<section class="section">
  <div class="container">
    <h2 class="section-title"><%= t.home.testimonials_title %></h2>
    <div class="row g-4">
      <% testimonials.forEach(tm => { %>
        <div class="col-md-6 col-lg-4">
          <div class="testimonial-card">
            <div class="quote-mark">&rdquo;</div>
            <p class="quote">&ldquo;<%= lang === 'en' && tm.content_en ? tm.content_en : tm.content %>&rdquo;</p>
            <div class="testimonial-author">
              <% if (tm.avatar) { %>
                <img src="<%= tm.avatar %>" alt="<%= tm.student_name %>">
              <% } else { %>
                <div class="placeholder-img placeholder-round" style="width:48px;height:48px;font-size:1.2rem;"><i class="bi bi-person"></i></div>
              <% } %>
              <div>
                <div class="student-name"><%= tm.student_name %></div>
                <% if (tm.course_name) { %><small class="student-course"><%= tm.course_name %></small><% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="section bg-alt">
  <div class="container">
    <h2 class="section-title"><%= t.home.posts_title %></h2>
    <% if (posts.length === 0) { %>
      <div class="empty-state"><i class="bi bi-newspaper"></i><%= t.posts.empty %></div>
    <% } else { %>
      <div class="row g-4">
        <% posts.forEach(post => { %>
          <div class="col-md-4">
            <div class="card-custom">
              <% if (post.thumbnail) { %>
                <img src="<%= post.thumbnail %>" alt="<%= post.title %>" class="post-card-thumb" style="width:100%;object-fit:cover;">
              <% } else { %>
                <div class="placeholder-img post-card-thumb"><i class="bi bi-newspaper"></i></div>
              <% } %>
              <div class="card-body">
                <h5><%= lang === 'en' && post.title_en ? post.title_en : post.title %></h5>
                <p class="text-muted small"><%= lang === 'en' && post.excerpt_en ? post.excerpt_en : post.excerpt %></p>
                <a href="/posts/<%= post.slug %>" class="btn-outline-navy btn btn-sm"><%= t.posts.read_more %></a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
    <div class="text-center mt-4"><a href="/posts" class="btn-navy btn"><%= t.home.posts_view_all %></a></div>
  </div>
</section>

<section class="section" id="registerTest">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <div class="register-card">
          <h2><%= t.home.register_title %></h2>
          <p class="text-muted"><%= t.home.register_subtitle %></p>
          <form action="/dang-ky" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="redirect_to" value="/#registerTest">
            <div class="mb-3">
              <label class="form-label"><%= t.schedule.full_name %> *</label>
              <input type="text" name="full_name" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label"><%= t.schedule.email %></label>
              <input type="email" name="email" class="form-control">
            </div>
            <div class="mb-3">
              <label class="form-label"><%= t.schedule.phone %> *</label>
              <input type="text" name="phone" class="form-control" required>
            </div>
            <button type="submit" class="btn-pink btn w-100 btn-lg"><%= t.home.register_submit %></button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
