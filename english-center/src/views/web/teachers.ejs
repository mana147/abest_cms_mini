<%- include('../partials/header', { pageCss: 'teachers' }) %>

<div class="page-banner">
  <div class="container">
    <h1><%= t.teachers.title %></h1>
  </div>
</div>

<section class="section">
  <div class="container">
    <% if (teachers.length === 0) { %>
      <div class="empty-state"><i class="bi bi-person-x"></i><%= t.teachers.empty %></div>
    <% } else { %>
      <div class="row g-4">
        <% teachers.forEach(teacher => { %>
          <div class="col-md-3 col-6">
            <div class="card-custom teacher-grid-card">
              <% if (teacher.photo) { %>
                <img src="<%= teacher.photo %>" alt="<%= teacher.name %>" style="width:130px;height:130px;object-fit:cover;border-radius:50%;margin:0 auto 1.25rem;display:block;">
              <% } else { %>
                <div class="placeholder-img placeholder-round"><i class="bi bi-person"></i></div>
              <% } %>
              <h5><%= teacher.name %></h5>
              <p class="text-muted small mb-1"><%= lang === 'en' && teacher.qualification_en ? teacher.qualification_en : teacher.qualification %></p>
              <p class="teacher-experience"><%= teacher.experience %></p>
              <% if (teacher.bio) { %><p class="text-muted small"><%= lang === 'en' && teacher.bio_en ? teacher.bio_en : teacher.bio %></p><% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
