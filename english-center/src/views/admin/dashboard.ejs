<% const activePage = 'dashboard'; %>
<%- include('../partials/admin-header') %>

<div class="row g-4">
  <div class="col-md-3 col-6">
    <div class="stat-card">
      <div class="stat-icon"><i class="bi bi-journal-bookmark"></i></div>
      <div>
        <div class="stat-value"><%= stats.courses %></div>
        <div class="stat-label">Khóa học</div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="stat-card">
      <div class="stat-icon"><i class="bi bi-person-badge"></i></div>
      <div>
        <div class="stat-value"><%= stats.teachers %></div>
        <div class="stat-label">Giáo viên</div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="stat-card">
      <div class="stat-icon"><i class="bi bi-newspaper"></i></div>
      <div>
        <div class="stat-value"><%= stats.posts %></div>
        <div class="stat-label">Tin tức</div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="stat-card">
      <div class="stat-icon"><i class="bi bi-card-checklist"></i></div>
      <div>
        <div class="stat-value"><%= stats.registrations %></div>
        <div class="stat-label">Đăng ký học</div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mt-1">
  <div class="col-md-6">
    <div class="admin-card d-flex align-items-center justify-content-between">
      <div>
        <h5 class="mb-1"><i class="bi bi-envelope-exclamation text-gold"></i> Đăng ký chưa đọc</h5>
        <p class="text-muted mb-0">Có <%= stats.registrationsUnread %> đăng ký học chưa được xem</p>
      </div>
      <a href="/admin/registrations" class="btn-outline-navy btn">Xem ngay</a>
    </div>
  </div>
  <div class="col-md-6">
    <div class="admin-card d-flex align-items-center justify-content-between">
      <div>
        <h5 class="mb-1"><i class="bi bi-chat-square-exclamation text-gold"></i> Liên hệ chưa đọc</h5>
        <p class="text-muted mb-0">Có <%= stats.contactsUnread %> liên hệ chưa được xem</p>
      </div>
      <a href="/admin/contacts" class="btn-outline-navy btn">Xem ngay</a>
    </div>
  </div>
</div>

<%- include('../partials/admin-footer') %>
