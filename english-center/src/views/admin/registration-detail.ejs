<% const activePage = 'registrations'; %>
<%- include('../partials/admin-header') %>

<div class="admin-card" style="max-width:600px;">
  <dl class="row mb-0">
    <dt class="col-4">Họ tên</dt><dd class="col-8"><%= registration.full_name %></dd>
    <dt class="col-4">Số điện thoại</dt><dd class="col-8"><%= registration.phone %></dd>
    <dt class="col-4">Email</dt><dd class="col-8"><%= registration.email || '-' %></dd>
    <dt class="col-4">Khóa học</dt><dd class="col-8"><%= registration.course_title || '-' %></dd>
    <dt class="col-4">Lời nhắn</dt><dd class="col-8"><%= registration.message || '-' %></dd>
    <dt class="col-4">Ngày đăng ký</dt><dd class="col-8"><%= new Date(registration.created_at).toLocaleString('vi-VN') %></dd>
  </dl>
  <a href="/admin/registrations" class="btn btn-outline-secondary mt-3">Quay lại</a>
  <form action="/admin/registrations/<%= registration.id %>/delete" method="POST" class="d-inline" data-confirm="Xóa đăng ký này?">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="btn btn-outline-danger mt-3">Xóa</button>
  </form>
</div>

<%- include('../partials/admin-footer') %>
