<% const activePage = 'contacts'; %>
<%- include('../partials/admin-header') %>

<div class="admin-card" style="max-width:600px;">
  <dl class="row mb-0">
    <dt class="col-4">Họ tên</dt><dd class="col-8"><%= contact.full_name %></dd>
    <dt class="col-4">Email</dt><dd class="col-8"><%= contact.email || '-' %></dd>
    <dt class="col-4">Số điện thoại</dt><dd class="col-8"><%= contact.phone || '-' %></dd>
    <dt class="col-4">Chủ đề</dt><dd class="col-8"><%= contact.subject || '-' %></dd>
    <dt class="col-4">Nội dung</dt><dd class="col-8"><%= contact.message %></dd>
    <dt class="col-4">Ngày gửi</dt><dd class="col-8"><%= new Date(contact.created_at).toLocaleString('vi-VN') %></dd>
  </dl>
  <a href="/admin/contacts" class="btn btn-outline-secondary mt-3">Quay lại</a>
  <form action="/admin/contacts/<%= contact.id %>/delete" method="POST" class="d-inline" data-confirm="Xóa liên hệ này?">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="btn btn-outline-danger mt-3">Xóa</button>
  </form>
</div>

<%- include('../partials/admin-footer') %>
