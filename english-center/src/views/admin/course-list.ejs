<% const activePage = 'courses'; %>
<%- include('../partials/admin-header') %>

<div class="admin-card">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Danh sách khóa học</h5>
    <a href="/admin/courses/create" class="btn-gold btn"><i class="bi bi-plus-lg"></i> Thêm khóa học</a>
  </div>
  <% if (courses.length === 0) { %>
    <div class="empty-state"><i class="bi bi-journal-x"></i>Chưa có khóa học nào</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-admin">
        <thead>
          <tr>
            <th>Ảnh</th><th>Tiêu đề</th><th>Trình độ</th><th>Học phí</th><th>Trạng thái</th><th></th>
          </tr>
        </thead>
        <tbody>
          <% courses.forEach(course => { %>
            <tr>
              <td>
                <% if (course.thumbnail) { %>
                  <img src="<%= course.thumbnail %>" class="thumb-sm" alt="">
                <% } else { %>
                  <div class="thumb-sm placeholder-img" style="aspect-ratio:1;"><i class="bi bi-journal-bookmark"></i></div>
                <% } %>
              </td>
              <td><%= course.title %></td>
              <td><%= course.level || '-' %></td>
              <td><%= course.fee || '-' %></td>
              <td>
                <% if (course.status === 'published') { %>
                  <span class="badge bg-success">Đã đăng</span>
                <% } else { %>
                  <span class="badge bg-secondary">Bản nháp</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/admin/courses/<%= course.id %>/edit" class="btn btn-sm btn-outline-navy"><i class="bi bi-pencil"></i></a>
                <form action="/admin/courses/<%= course.id %>/delete" method="POST" class="d-inline" data-confirm="Xóa khóa học này?">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/admin-footer') %>
